<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161B22"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DroidNode Debug"
            android:textColor="#E6EDF3"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAgentStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● STOPPED"
            android:textColor="#F85149"
            android:textSize="12sp"
            android:typeface="monospace"/>
    </LinearLayout>

    <!-- Node ID strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#21262D"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tvNodeId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="node: starting..."
            android:textColor="#8B949E"
            android:textSize="11sp"
            android:typeface="monospace"
            android:singleLine="true"
            android:ellipsize="middle"/>
    </LinearLayout>

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#161B22"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabLogs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="LOGS"
            android:textSize="12sp"
            android:textColor="#58A6FF"
            android:background="#0D1117"
            android:typeface="monospace"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="STATUS"
            android:textSize="12sp"
            android:textColor="#8B949E"
            android:background="#161B22"
            android:typeface="monospace"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabPods"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="PODS"
            android:textSize="12sp"
            android:textColor="#8B949E"
            android:background="#161B22"
            android:typeface="monospace"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- LOGS content -->
    <ScrollView
        android:id="@+id/scrollLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D1117"
        android:fillViewport="true">

        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6EDF3"
            android:textSize="11sp"
            android:typeface="monospace"
            android:padding="12dp"
            android:lineSpacingMultiplier="1.3"
            android:textIsSelectable="true"/>
    </ScrollView>

    <!-- STATUS content -->
    <ScrollView
        android:id="@+id/scrollStatus"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D1117"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6EDF3"
            android:textSize="12sp"
            android:typeface="monospace"
            android:padding="16dp"
            android:lineSpacingMultiplier="1.5"
            android:textIsSelectable="true"/>
    </ScrollView>

    <!-- PODS content -->
    <ScrollView
        android:id="@+id/scrollPods"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D1117"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvPods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6EDF3"
            android:textSize="12sp"
            android:typeface="monospace"
            android:padding="16dp"
            android:lineSpacingMultiplier="1.5"
            android:textIsSelectable="true"/>
    </ScrollView>

</LinearLayout>
